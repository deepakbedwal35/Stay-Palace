<div class="review-form-card">
    <h3 class="review-form-title">Share your experience</h3>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
      
      <!-- Star Rating -->
      <div class="mb-form">
        <label class="form-label-sp">Your Rating</label>
        <div class="rating-stars-input">
          <input type="radio" id="star5" name="review[rating]" value="5" required>
          <label for="star5" title="5 stars">&#9733;</label>
          <input type="radio" id="star4" name="review[rating]" value="4">
          <label for="star4" title="4 stars">&#9733;</label>
          <input type="radio" id="star3" name="review[rating]" value="3">
          <label for="star3" title="3 stars">&#9733;</label>
          <input type="radio" id="star2" name="review[rating]" value="2">
          <label for="star2" title="2 stars">&#9733;</label>
          <input type="radio" id="star1" name="review[rating]" value="1">
          <label for="star1" title="1 star">&#9733;</label>
        </div>
      </div>

      <!-- Comment -->
      <div class="mb-form">
        <label for="comment" class="form-label-sp">Your Review</label>
        <textarea id="comment" name="review[comment]" rows="4" 
          class="form-control-sp" 
          placeholder="What did you love about this place? What could be improved?" 
          required></textarea>
      </div>

      <button type="submit" class="btn btn-secondary" style="margin-top:0.25rem;">
        <i class="fa-solid fa-paper-plane me-2">Submit Review</i>
      </button>
    </form>
</div>